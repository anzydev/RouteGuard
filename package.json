{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "node ./scripts/bootstrap-pnpm.cjs",
    "postinstall": "node ./scripts/postinstall-workspace.cjs",
    "db:push": "pnpm --filter @workspace/db run push",
    "dev:api": "pnpm --filter @workspace/api-server run dev",
    "dev:web": "PORT=5173 BASE_PATH=/ pnpm --filter @workspace/transit run dev",
    "dev": "concurrently --kill-others-on-fail --names api,web --prefix-colors yellow,cyan \"npm:dev:api\" \"npm:dev:web\"",
    "build": "pnpm run typecheck:libs && pnpm --filter @workspace/api-server run build && pnpm --filter @workspace/transit run build",
    "start": "bash ./start.sh",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  }
}
