# Copy this file to .env and fill in the values, then run ./start.sh
# ---------------------------------------------------------------------------

# Required: Postgres connection string.
# Local example:    postgres://postgres:postgres@localhost:5432/transit
# Neon / Supabase:  paste the connection string from your dashboard.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/transit

# Required: any long random string. Used for session cookies.
SESSION_SECRET=replace-me-with-a-long-random-string

# Optional: enables AI Mission Briefing + natural-language Command Bar.
# Without these, the app falls back to deterministic templates (still works).
# AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
# AI_INTEGRATIONS_OPENAI_API_KEY=sk-...
